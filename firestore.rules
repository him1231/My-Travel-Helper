rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(data) {
      return isSignedIn() && request.auth.uid == data.ownerId;
    }

    function isMember(data) {
      return isSignedIn() && request.auth.uid in data.memberIds;
    }

    match /users/{uid} {
      allow read: if isSignedIn();
      allow write: if isSignedIn() && request.auth.uid == uid;
    }

    match /trips/{tripId} {
      allow read: if isOwner(resource.data)
                  || isMember(resource.data)
                  || (resource.data.shareToken != null && resource.data.shareToken != '');
      allow create: if isSignedIn()
                       && request.auth.uid == request.resource.data.ownerId
                       && request.auth.uid in request.resource.data.memberIds;
      allow update: if isOwner(resource.data) || isMember(resource.data);
      allow delete: if isOwner(resource.data);

      match /days/{dayId} {
        function trip() {
          return get(/databases/$(database)/documents/trips/$(tripId)).data;
        }
        allow read: if isOwner(trip()) || isMember(trip())
                    || (trip().shareToken != null && trip().shareToken != '');
        allow write: if isOwner(trip()) || isMember(trip());
      }

      match /lists/{listId} {
        function trip() {
          return get(/databases/$(database)/documents/trips/$(tripId)).data;
        }
        allow read: if isOwner(trip()) || isMember(trip())
                    || (trip().shareToken != null && trip().shareToken != '');
        allow write: if isOwner(trip()) || isMember(trip());
      }
    }
  }
}
